{
  "kind": "collectionType",
  "collectionName": "restaurant_images",
  "info": {
    "singularName": "restaurant-image",
    "pluralName": "restaurant-images",
    "displayName": "Restaurant Image"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "altText": {
      "type": "string",
      "required": true
    },
    "restaurant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::restaurant.restaurant",
      "inversedBy": "images"
    }
  }
}

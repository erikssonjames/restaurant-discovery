{
  "kind": "collectionType",
  "collectionName": "cuisines",
  "info": {
    "singularName": "cuisine",
    "pluralName": "cuisines",
    "displayName": "Cuisine"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "blocks",
      "required": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "restaurants": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::restaurant.restaurant",
      "inversedBy": "cuisines"
    }
  }
}

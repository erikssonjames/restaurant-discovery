{
  "kind": "collectionType",
  "collectionName": "restaurants",
  "info": {
    "singularName": "restaurant",
    "pluralName": "restaurants",
    "displayName": "Restaurant"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "address": {
      "type": "string",
      "required": true
    },
    "postalCode": {
      "type": "string"
    },
    "description": {
      "type": "blocks",
      "required": true
    },
    "priceRange": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "budget",
        "moderate",
        "upscale",
        "fine_dining"
      ]
    },
    "website": {
      "type": "string"
    },
    "phoneNumber": {
      "type": "string"
    },
    "isOpen": {
      "type": "boolean",
      "default": true
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false,
      "required": true
    },
    "aggregateRating": {
      "type": "component",
      "component": "shared.aggregate-rating",
      "repeatable": false
    },
    "city": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::city.city",
      "inversedBy": "restaurants"
    },
    "cuisines": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cuisine.cuisine",
      "mappedBy": "restaurants"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "restaurant"
    },
    "images": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::restaurant-image.restaurant-image",
      "mappedBy": "restaurant"
    }
  }
}
